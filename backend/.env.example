# ──────────────────────────────────────────────────────────────────
# Anti-Fraud Backend · 环境变量样板
#
# 启动时由 Pydantic Settings 加载并强校验；缺失必填项服务会立刻退出。
# 真实 .env 严禁入库（已在 .gitignore + .dockerignore 双重保险）。
# ──────────────────────────────────────────────────────────────────

# ── 应用环境 ─────────────────────────────────────────────────────
# 取值: local / dev / staging / prod / test
APP_ENV=local
APP_NAME=anti-fraud-backend
APP_VERSION=0.1.0
DEBUG=true
LOG_LEVEL=DEBUG          # DEBUG / INFO / WARNING / ERROR
LOG_FORMAT=console       # console (开发) / json (生产)

# ── 网络 ─────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
ROOT_PATH=
# 允许跨域的来源（生产环境应只列学校自己的前端域名）
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── 安全 ─────────────────────────────────────────────────────────
# Cookie 签名 + 各种 token 签名用，长度 ≥ 32。生产环境从 Vault 注入
SECRET_KEY=change-me-please-use-32-bytes-or-more
SESSION_COOKIE_NAME=afp_session
SESSION_COOKIE_DOMAIN=
SESSION_COOKIE_SECURE=false   # prod 必须 true
SESSION_COOKIE_SAMESITE=lax
SESSION_TTL_SECONDS=1800      # 30 分钟滑动过期

# ── 数据库 ───────────────────────────────────────────────────────
# async 用 aiomysql；sync (alembic) 自动在内部转换
DATABASE_URL=mysql+aiomysql://app_user:apppassword@mysql:3306/anti_fraud?charset=utf8mb4
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_RECYCLE=1800
DATABASE_ECHO=false           # SQLAlchemy SQL 回显，仅在调试时开启

# ── Redis ────────────────────────────────────────────────────────
REDIS_URL=redis://:redispassword@redis:6379/0
REDIS_KEY_PREFIX=afp
REDIS_AUDIT_STREAM_KEY=afp:audit:stream
REDIS_AUDIT_STREAM_MAXLEN=100000

# ── CAS ──────────────────────────────────────────────────────────
# real / mock。开发默认 mock，生产强制 real
AUTH_PROVIDER=mock
CAS_SERVER_URL=https://cas.example.edu.cn/cas
CAS_SERVICE_URL=http://localhost:8000/api/v1/auth/cas/callback
# 允许的回调白名单（service 参数严格校验，逗号分隔）
CAS_SERVICE_WHITELIST=http://localhost:8000/api/v1/auth/cas/callback,http://localhost:5173/auth/callback
CAS_TIMEOUT_SECONDS=10
CAS_HEALTH_CHECK_INTERVAL_SECONDS=60

# Mock CAS 用：登录页直接接收 cas_account 即视为通过
MOCK_CAS_ALLOW_ANY=true

# ── KMS（密钥托管） ─────────────────────────────────────────────
# local: 本地主密钥（仅 dev/test）；vault: 接学校 Vault；aws: AWS KMS
KMS_PROVIDER=local
# 32 字节 base64。生产从 Vault 拉，绝不入库
KMS_LOCAL_MASTER_KEY=ZGV2LW1hc3Rlci1rZXktbm90LWZvci1wcm9kdWN0aW9uLXVzZSE=
KMS_DATA_KEY_VERSION=v1

# ── 对象存储（证据文件） ──────────────────────────────────────
# local: 加密后写入 EVIDENCE_UPLOAD_DIR；s3: 加密后写入 MinIO/S3
STORAGE_BACKEND=local
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin123
S3_BUCKET=evidence
S3_REGION=us-east-1
S3_USE_SSL=false
S3_SERVER_SIDE_ENCRYPTION=false

# ── 雪花 ID ──────────────────────────────────────────────────────
SNOWFLAKE_DATACENTER_ID=1
SNOWFLAKE_WORKER_ID=1
SNOWFLAKE_EPOCH_MS=1735689600000   # 2025-01-01 00:00:00 UTC

# ── 司法协助查询 ─────────────────────────────────────────────────
JUDICIAL_DECRYPT_WINDOW_SECONDS=300   # 5 分钟
JUDICIAL_NOTIFY_ALL_SYSADMINS=true

# ── 审计 SDK ─────────────────────────────────────────────────────
AUDIT_ASYNC_ENABLED=true
AUDIT_FALLBACK_PATH=/app/logs/audit_fallback.jsonl
AUDIT_HASH_CHAIN_ENABLED=true

# ── 可观测性 ─────────────────────────────────────────────────────
PROMETHEUS_ENABLED=true
PROMETHEUS_PATH=/metrics

# ── OpenAPI 暴露控制 ────────────────────────────────────────────
# 生产环境关闭或加管理员鉴权（/docs /redoc /openapi.json）
OPENAPI_ENABLED=true
