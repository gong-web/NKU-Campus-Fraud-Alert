# ──────────────────────────────────────────────────────────────────
# 基础设施环境变量（docker-compose 顶层使用）
# 真实 .env 严禁入库
# ──────────────────────────────────────────────────────────────────

# MySQL
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=anti_fraud
MYSQL_USER=app_user
MYSQL_PASSWORD=apppassword
MYSQL_PORT=3306

# 司法协助专用账号（PRD 5.5.3 物理权限隔离）
DECRYPT_DB_USER=decrypt_user
DECRYPT_DB_PASSWORD=decryptpassword

# Redis
REDIS_PASSWORD=redispassword
REDIS_PORT=6379

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# 前后端端口
BACKEND_PORT=8000
FRONTEND_PORT=5173
APP_ENV=local
